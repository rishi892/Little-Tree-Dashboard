# Get these from https://developer.intuit.com → your app → Keys & credentials
QBO_CLIENT_ID=your_client_id_here
QBO_CLIENT_SECRET=your_client_secret_here

# 'production' or 'sandbox'
QBO_ENVIRONMENT=production

# Must match a Redirect URI registered on your Intuit app.
# Production: https://cfovaani.com/auth/callback
# The server itself runs at https://cfovaani.com on Replit and serves both
#  so Intuit calls cfovaani.com directly and the browser sees one origin)
QBO_REDIRECT_URI=http://localhost:4747/auth/callback

# Where the React client lives (used for the post-auth redirect target).
# Production: https://cfovaani.com/cashflow.html
CLIENT_URL=http://localhost:4748

# Extra browser origins permitted by the CORS middleware. Defaults below
# already cover cfovaani.com + localhost — only set this if you add another
# domain (e.g. a staging URL). Comma-separated, no spaces around commas.
# ALLOWED_ORIGINS=https://staging.cfovaani.com

PORT=4747
