# Replit entry config. Single Node process serves the AR Dashboard +
# Cashflow Dashboard frontends plus the Cashflow API on one port.

run        = "npm start"
entrypoint = "cashflow-server/src/index.ts"

modules = ["nodejs-20"]

[nix]
channel = "stable-23_11"

[deployment]
# To move to an always-on Replit host later, switch this to "gce" (Reserved VM)
# in the Replit Deployments UI - see REPLIT_MIGRATION.md. Left as "cloudrun" for
# now so the existing Replit setup is unchanged.
deploymentTarget = "cloudrun"
# Build the frontend bundles + compile the server, then start it.
build = ["sh", "-c", "npm run install:all && npm run build:all"]
run   = ["sh", "-c", "npm start"]

[env]
NODE_ENV = "production"

[[ports]]
localPort    = 4747
externalPort = 80
